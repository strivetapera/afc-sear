{
  "name": "afc-sear",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "export": "next export",
    "lint": "next lint",
    "api:dev": "npm run --workspace @afc-sear/api dev",
    "api:build": "npm run --workspace @afc-sear/api build",
    "api:typecheck": "npm run --workspace @afc-sear/api typecheck",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "npm run --workspace @afc-sear/db migrate:deploy",
    "db:migrate:status": "npm run --workspace @afc-sear/db migrate:status",
    "db:generate": "npm run --workspace @afc-sear/db generate",
    "db:validate": "npm run --workspace @afc-sear/db validate",
    "db:format": "npm run --workspace @afc-sear/db format",
    "db:seed": "npm run --workspace @afc-sear/db seed"
  },
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "lottie-web": "^5.12.2",
    "next": "^15.5.14",
    "nextjs": "^0.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-player": "^3.4.0",
    "react-youtube": "^10.1.0",
    "video.js": "^8.23.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "eslint": "^9",
    "eslint-config-next": "15.1.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  },
  "overrides": {
    "framer-motion": "11.11.17"
  }
}
