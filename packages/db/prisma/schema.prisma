generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String            @id @default(uuid()) @db.Uuid
  email              String            @unique
  phone              String?           @unique
  passwordHash       String?           @map("password_hash")
  status             UserStatus        @default(INVITED)
  isActive           Boolean           @default(true) @map("is_active")
  lastLoginAt        DateTime?         @map("last_login_at")
  defaultBranchId    String?           @map("default_branch_id") @db.Uuid
  personId           String?           @unique @map("person_id") @db.Uuid
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  assignedApprovals  ApprovalRequest[] @relation("ApprovalAssignedTo")
  requestedApprovals ApprovalRequest[] @relation("ApprovalRequestedBy")
  auditLogs          AuditLog[]
  authoredContent    ContentItem[]     @relation("ContentAuthor")
  contentVersions    ContentVersion[]
  uploadedAssets     MediaAsset[]
  mfaMethods         MfaMethod[]
  sessions           Session[]
  userRoles          UserRole[]
  defaultBranch      Branch?           @relation("UserDefaultBranch", fields: [defaultBranchId], references: [id])
  person             Person?           @relation(fields: [personId], references: [id])

  @@map("users")
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  key         String           @unique
  name        String
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  permissions RolePermission[]
  userRoles   UserRole[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  key         String           @unique
  name        String
  domain      String
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid()) @db.Uuid
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model Session {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  deviceLabel String?  @map("device_label")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model MfaMethod {
  id         String        @id @default(uuid()) @db.Uuid
  userId     String        @map("user_id") @db.Uuid
  type       MfaMethodType
  label      String?
  secretRef  String        @map("secret_ref")
  isVerified Boolean       @default(false) @map("is_verified")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("mfa_methods")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  action      String
  domain      String
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  before      Json?
  after       Json?
  ipAddress   String?  @map("ip_address")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  actorUser   User?    @relation(fields: [actorUserId], references: [id])

  @@index([actorUserId])
  @@index([domain, entityType, entityId])
  @@map("audit_logs")
}

model Region {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  code      String    @unique
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  countries Country[]

  @@map("regions")
}

model Country {
  id           String   @id @default(uuid()) @db.Uuid
  regionId     String   @map("region_id") @db.Uuid
  name         String
  code         String   @unique
  currencyCode String   @map("currency_code")
  timezone     String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  branches     Branch[]
  region       Region   @relation(fields: [regionId], references: [id])

  @@index([regionId])
  @@map("countries")
}

model Branch {
  id            String          @id @default(uuid()) @db.Uuid
  countryId     String          @map("country_id") @db.Uuid
  name          String
  slug          String          @unique
  type          String
  email         String?
  phone         String?
  addressLine1  String?         @map("address_line_1")
  city          String?
  latitude      Decimal?        @db.Decimal(10, 7)
  longitude     Decimal?        @db.Decimal(10, 7)
  isPublic      Boolean         @default(true) @map("is_public")
  metadata      Json?
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  country       Country         @relation(fields: [countryId], references: [id])
  contentItems  ContentItem[]
  events        Event[]
  households    Household[]
  joinedMembers MemberProfile[]
  ministries    Ministry[]
  people        Person[]
  userRoles     UserRole[]
  defaultUsers  User[]          @relation("UserDefaultBranch")
  venues        Venue[]
  announcements Announcement[]
  funds Fund[]
  attendanceRecords AttendanceRecord[]
  tasks Task[]
  documents Document[]

  @@index([countryId])
  @@map("branches")
}

model Ministry {
  id          String             @id @default(uuid()) @db.Uuid
  branchId    String?            @map("branch_id") @db.Uuid
  name        String
  slug        String
  description String?
  visibility  MinistryVisibility @default(PRIVATE)
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  branch      Branch?            @relation(fields: [branchId], references: [id])
  userRoles   UserRole[]

  @@unique([branchId, slug])
  @@index([branchId])
  @@map("ministries")
}

model UserRole {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  roleId     String    @map("role_id") @db.Uuid
  branchId   String?   @map("branch_id") @db.Uuid
  ministryId String?   @map("ministry_id") @db.Uuid
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  branch     Branch?   @relation(fields: [branchId], references: [id])
  ministry   Ministry? @relation(fields: [ministryId], references: [id])
  role       Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, branchId, ministryId])
  @@index([userId])
  @@index([roleId])
  @@index([branchId])
  @@index([ministryId])
  @@map("user_roles")
}

model Person {
  id                       String                   @id @default(uuid()) @db.Uuid
  firstName                String                   @map("first_name")
  lastName                 String                   @map("last_name")
  middleName               String?                  @map("middle_name")
  preferredName            String?                  @map("preferred_name")
  email                    String?
  phone                    String?
  dateOfBirth              DateTime?                @map("date_of_birth")
  gender                   String?
  branchId                 String?                  @map("branch_id") @db.Uuid
  lifecycleStage           PersonLifecycleStage     @default(VISITOR) @map("lifecycle_stage")
  createdAt                DateTime                 @default(now()) @map("created_at")
  updatedAt                DateTime                 @updatedAt @map("updated_at")
  communicationPreference  CommunicationPreference?
  householdMemberships     HouseholdMember[]
  primaryContactHouseholds Household[]              @relation("HouseholdPrimaryContact")
  memberProfile            MemberProfile?
  branch                   Branch?                  @relation(fields: [branchId], references: [id])
  user                     User?
  visitorProfile           VisitorProfile?

  @@index([branchId])
  @@index([email])
  @@index([phone])
  @@map("people")
}

model Household {
  id                     String            @id @default(uuid()) @db.Uuid
  branchId               String            @map("branch_id") @db.Uuid
  displayName            String            @map("display_name")
  primaryContactPersonId String?           @map("primary_contact_person_id") @db.Uuid
  addressLine1           String?           @map("address_line_1")
  city                   String?
  createdAt              DateTime          @default(now()) @map("created_at")
  updatedAt              DateTime          @updatedAt @map("updated_at")
  members                HouseholdMember[]
  branch                 Branch            @relation(fields: [branchId], references: [id])
  primaryContactPerson   Person?           @relation("HouseholdPrimaryContact", fields: [primaryContactPersonId], references: [id])

  @@unique([branchId, displayName])
  @@index([branchId])
  @@index([primaryContactPersonId])
  @@map("households")
}

model HouseholdMember {
  id               String    @id @default(uuid()) @db.Uuid
  householdId      String    @map("household_id") @db.Uuid
  personId         String    @map("person_id") @db.Uuid
  relationshipType String    @map("relationship_type")
  isPrimaryContact Boolean   @default(false) @map("is_primary_contact")
  createdAt        DateTime  @default(now()) @map("created_at")
  household        Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  person           Person    @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([householdId, personId])
  @@index([personId])
  @@map("household_members")
}

model MemberProfile {
  id               String           @id @default(uuid()) @db.Uuid
  personId         String           @unique @map("person_id") @db.Uuid
  membershipStatus MembershipStatus @default(PROSPECTIVE) @map("membership_status")
  joinedBranchId   String?          @map("joined_branch_id") @db.Uuid
  joinedOn         DateTime?        @map("joined_on")
  baptizedOn       DateTime?        @map("baptized_on")
  sanctifiedOn     DateTime?        @map("sanctified_on")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  joinedBranch     Branch?          @relation(fields: [joinedBranchId], references: [id])
  person           Person           @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([joinedBranchId])
  @@map("member_profiles")
}

model VisitorProfile {
  id             String         @id @default(uuid()) @db.Uuid
  personId       String         @unique @map("person_id") @db.Uuid
  firstVisitOn   DateTime?      @map("first_visit_on")
  source         String?
  followUpStatus FollowUpStatus @default(NEW) @map("follow_up_status")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  person         Person         @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@map("visitor_profiles")
}

model CommunicationPreference {
  id            String   @id @default(uuid()) @db.Uuid
  personId      String   @unique @map("person_id") @db.Uuid
  emailOptIn    Boolean  @default(true) @map("email_opt_in")
  smsOptIn      Boolean  @default(false) @map("sms_opt_in")
  whatsappOptIn Boolean  @default(false) @map("whatsapp_opt_in")
  pushOptIn     Boolean  @default(false) @map("push_opt_in")
  language      String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  person        Person   @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@map("communication_preferences")
}

model ContentType {
  id           String        @id @default(uuid()) @db.Uuid
  key          String        @unique
  name         String
  description  String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  contentItems ContentItem[]

  @@map("content_types")
}

model ContentItem {
  id            String                @id @default(uuid()) @db.Uuid
  contentTypeId String                @map("content_type_id") @db.Uuid
  branchId      String?               @map("branch_id") @db.Uuid
  authorUserId  String?               @map("author_user_id") @db.Uuid
  title         String
  slug          String                @unique
  summary       String?
  status        ContentStatus         @default(DRAFT)
  visibility    VisibilityScope       @default(PUBLIC)
  publishedAt   DateTime?             @map("published_at")
  scheduledFor  DateTime?             @map("scheduled_for")
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")
  metadata      Json?
  approvals     ApprovalRequest[]
  categories    ContentItemCategory[]
  tags          ContentItemTag[]
  authorUser    User?                 @relation("ContentAuthor", fields: [authorUserId], references: [id])
  branch        Branch?               @relation(fields: [branchId], references: [id])
  contentType   ContentType           @relation(fields: [contentTypeId], references: [id])
  versions      ContentVersion[]

  @@index([contentTypeId])
  @@index([branchId])
  @@index([authorUserId])
  @@index([status, visibility])
  @@map("content_items")
}

model ContentVersion {
  id            String      @id @default(uuid()) @db.Uuid
  contentItemId String      @map("content_item_id") @db.Uuid
  versionNumber Int         @map("version_number")
  body          Json
  seo           Json?
  changeNote    String?     @map("change_note")
  createdById   String?     @map("created_by_id") @db.Uuid
  createdAt     DateTime    @default(now()) @map("created_at")
  contentItem   ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  createdBy     User?       @relation(fields: [createdById], references: [id])

  @@unique([contentItemId, versionNumber])
  @@index([createdById])
  @@map("content_versions")
}

model Category {
  id           String                @id @default(uuid()) @db.Uuid
  name         String
  slug         String                @unique
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")
  contentItems ContentItemCategory[]

  @@map("categories")
}

model Tag {
  id           String           @id @default(uuid()) @db.Uuid
  name         String
  slug         String           @unique
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  contentItems ContentItemTag[]

  @@map("tags")
}

model ContentItemCategory {
  id            String      @id @default(uuid()) @db.Uuid
  contentItemId String      @map("content_item_id") @db.Uuid
  categoryId    String      @map("category_id") @db.Uuid
  category      Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  contentItem   ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)

  @@unique([contentItemId, categoryId])
  @@map("content_item_categories")
}

model ContentItemTag {
  id            String      @id @default(uuid()) @db.Uuid
  contentItemId String      @map("content_item_id") @db.Uuid
  tagId         String      @map("tag_id") @db.Uuid
  contentItem   ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([contentItemId, tagId])
  @@map("content_item_tags")
}

model MediaAsset {
  id           String          @id @default(uuid()) @db.Uuid
  storageKey   String          @unique @map("storage_key")
  originalName String          @map("original_name")
  mimeType     String          @map("mime_type")
  fileSize     Int             @map("file_size")
  width        Int?
  height       Int?
  uploadedById String?         @map("uploaded_by_id") @db.Uuid
  scanStatus   AssetScanStatus @default(PENDING) @map("scan_status")
  createdAt    DateTime        @default(now()) @map("created_at")
  uploadedBy   User?           @relation(fields: [uploadedById], references: [id])

  @@index([uploadedById])
  @@map("media_assets")
}

model ApprovalRequest {
  id            String         @id @default(uuid()) @db.Uuid
  domain        String
  entityType    String         @map("entity_type")
  entityId      String         @map("entity_id")
  contentItemId String?        @map("content_item_id") @db.Uuid
  requestedById String         @map("requested_by_id") @db.Uuid
  assignedToId  String?        @map("assigned_to_id") @db.Uuid
  status        ApprovalStatus @default(PENDING)
  decisionNote  String?        @map("decision_note")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  assignedTo    User?          @relation("ApprovalAssignedTo", fields: [assignedToId], references: [id])
  contentItem   ContentItem?   @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  requestedBy   User           @relation("ApprovalRequestedBy", fields: [requestedById], references: [id])

  @@index([domain, entityType, entityId])
  @@index([contentItemId])
  @@index([requestedById])
  @@index([assignedToId])
  @@map("approval_requests")
}

model Venue {
  id           String   @id @default(uuid()) @db.Uuid
  branchId     String?  @map("branch_id") @db.Uuid
  name         String
  addressLine1 String   @map("address_line_1")
  city         String
  capacity     Int?
  isVirtual    Boolean  @default(false) @map("is_virtual")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  events       Event[]
  branch       Branch?  @relation(fields: [branchId], references: [id])

  @@map("venues")
}

model Event {
  id               String            @id @default(uuid()) @db.Uuid
  branchId         String?           @map("branch_id") @db.Uuid
  venueId          String?           @map("venue_id") @db.Uuid
  title            String
  slug             String            @unique
  summary          String?
  description      Json?
  eventType        EventType         @default(SERVICE) @map("event_type")
  visibility       VisibilityScope   @default(PUBLIC)
  status           ContentStatus     @default(DRAFT)
  registrationMode RegistrationMode  @default(OPEN) @map("registration_mode")
  metadata         Json?
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  schedules        EventSchedule[]
  branch           Branch?           @relation(fields: [branchId], references: [id])
  venue            Venue?            @relation(fields: [venueId], references: [id])
  registrationForm RegistrationForm?
  registrations    Registration[]
  ticketTypes      TicketType[]

  @@map("events")
}

model EventSchedule {
  id             String   @id @default(uuid()) @db.Uuid
  eventId        String   @map("event_id") @db.Uuid
  startsAt       DateTime @map("starts_at")
  endsAt         DateTime @map("ends_at")
  timezone       String
  recurrenceRule String?  @map("recurrence_rule")
  virtualJoinUrl String?  @map("virtual_join_url")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_schedules")
}

model RegistrationForm {
  id        String   @id @default(uuid()) @db.Uuid
  eventId   String   @unique @map("event_id") @db.Uuid
  schema    Json
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("registration_forms")
}

model TicketType {
  id                    String                 @id @default(uuid()) @db.Uuid
  eventId               String                 @map("event_id") @db.Uuid
  name                  String
  priceMinor            Int                    @default(0) @map("price_minor")
  currencyCode          String                 @default("USD") @map("currency_code")
  capacity              Int?
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  registrationAttendees RegistrationAttendee[]
  event                 Event                  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("ticket_types")
}

model Registration {
  id            String                 @id @default(uuid()) @db.Uuid
  eventId       String                 @map("event_id") @db.Uuid
  personId      String?                @map("person_id") @db.Uuid
  householdId   String?                @map("household_id") @db.Uuid
  status        RegistrationStatus     @default(PENDING)
  totalMinor    Int                    @default(0) @map("total_minor")
  currencyCode  String                 @default("USD") @map("currency_code")
  paymentStatus PaymentStatus          @default(NOT_APPLICABLE) @map("payment_status")
  metadata      Json?
  createdAt     DateTime               @default(now()) @map("created_at")
  updatedAt     DateTime               @updatedAt @map("updated_at")
  attendees     RegistrationAttendee[]
  event         Event                  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([personId])
  @@index([householdId])
  @@map("registrations")
}

model RegistrationAttendee {
  id             String                @id @default(uuid()) @db.Uuid
  registrationId String                @map("registration_id") @db.Uuid
  personId       String?               @map("person_id") @db.Uuid
  fullName       String                @map("full_name")
  ticketTypeId   String?               @map("ticket_type_id") @db.Uuid
  checkInStatus  AttendeeCheckInStatus @default(PENDING) @map("check_in_status")
  metadata       Json?
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  checkIns       CheckIn[]
  registration   Registration          @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  ticketType     TicketType?           @relation(fields: [ticketTypeId], references: [id])

  @@index([registrationId])
  @@index([personId])
  @@map("registration_attendees")
}

model CheckIn {
  id                     String               @id @default(uuid()) @db.Uuid
  registrationAttendeeId String               @map("registration_attendee_id") @db.Uuid
  checkedInAt            DateTime             @default(now()) @map("checked_in_at")
  checkedInById          String?              @map("checked_in_by_id") @db.Uuid
  attendee               RegistrationAttendee @relation(fields: [registrationAttendeeId], references: [id], onDelete: Cascade)

  @@index([registrationAttendeeId])
  @@map("check_ins")
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  DEACTIVATED
}

enum MfaMethodType {
  TOTP
  SMS
  EMAIL
  BACKUP_CODE
}

enum MinistryVisibility {
  PUBLIC
  MEMBER
  PRIVATE
}

enum PersonLifecycleStage {
  VISITOR
  REGULAR_ATTENDEE
  MEMBER
  LEADER
  STAFF
}

enum MembershipStatus {
  PROSPECTIVE
  ACTIVE
  INACTIVE
  TRANSFERRED
}

enum FollowUpStatus {
  NEW
  IN_PROGRESS
  COMPLETED
  CLOSED
}

enum ContentStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED
}

enum VisibilityScope {
  PUBLIC
  MEMBER
  BRANCH
  MINISTRY
  PRIVATE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

enum AssetScanStatus {
  PENDING
  CLEAN
  QUARANTINED
  FAILED
}

enum EventType {
  SERVICE
  CONFERENCE
  CONCERT
  MEETING
  WORKSHOP
  SOCIAL
  OTHER
}

enum RegistrationMode {
  OPEN
  MEMBER_ONLY
  INVITATION_ONLY
  CLOSED
}

enum PaymentStatus {
  NOT_APPLICABLE
  PENDING
  AUTHORIZED
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  FAILED
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  CANCELED
  WAITLISTED
}

enum AttendeeCheckInStatus {
  PENDING
  CHECKED_IN
  NO_SHOW
}

// ─────────────────────────────────────────────
// COMMUNICATIONS
// ─────────────────────────────────────────────

model Announcement {
  id          String              @id @default(uuid()) @db.Uuid
  branchId    String?             @map("branch_id") @db.Uuid
  title       String
  body        Json
  visibility  VisibilityScope     @default(PUBLIC)
  publishedAt DateTime?           @map("published_at")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  branch      Branch?             @relation(fields: [branchId], references: [id])

  @@index([branchId])
  @@map("announcements")
}

model Campaign {
  id             String           @id @default(uuid()) @db.Uuid
  name           String
  channel        CampaignChannel
  audienceFilter Json             @map("audience_filter")
  status         CampaignStatus   @default(DRAFT)
  scheduledFor   DateTime?        @map("scheduled_for")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  recipients     MessageRecipient[]
  deliveryLogs   DeliveryLog[]

  @@map("campaigns")
}

model MessageTemplate {
  id        String          @id @default(uuid()) @db.Uuid
  channel   CampaignChannel
  key       String          @unique
  subject   String?
  body      String
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@map("message_templates")
}

model MessageRecipient {
  id             String         @id @default(uuid()) @db.Uuid
  campaignId     String         @map("campaign_id") @db.Uuid
  personId       String         @map("person_id") @db.Uuid
  deliveryStatus DeliveryStatus @default(PENDING) @map("delivery_status")
  createdAt      DateTime       @default(now()) @map("created_at")
  campaign       Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([personId])
  @@map("message_recipients")
}

model DeliveryLog {
  id                String         @id @default(uuid()) @db.Uuid
  channel           CampaignChannel
  provider          String
  personId          String?        @map("person_id") @db.Uuid
  campaignId        String?        @map("campaign_id") @db.Uuid
  externalMessageId String?        @map("external_message_id")
  status            DeliveryStatus
  errorMessage      String?        @map("error_message")
  createdAt         DateTime       @default(now()) @map("created_at")
  campaign          Campaign?      @relation(fields: [campaignId], references: [id])

  @@index([campaignId])
  @@index([personId])
  @@map("delivery_logs")
}

model SubscriptionTopic {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("subscription_topics")
}

enum CampaignChannel {
  EMAIL
  SMS
  WHATSAPP
  PUSH
}

enum CampaignStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENDING
  SENT
  CANCELED
}

enum DeliveryStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  BOUNCED
  UNSUBSCRIBED
}

// ─────────────────────────────────────────────
// FINANCE
// ─────────────────────────────────────────────

model Fund {
  id           String     @id @default(uuid()) @db.Uuid
  branchId     String?    @map("branch_id") @db.Uuid
  name         String
  code         String     @unique
  isRestricted Boolean    @default(false) @map("is_restricted")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  donations    Donation[]
  pledges      Pledge[]
  branch       Branch?    @relation(fields: [branchId], references: [id])

  @@index([branchId])
  @@map("funds")
}

model Payment {
  id                String        @id @default(uuid()) @db.Uuid
  personId          String?       @map("person_id") @db.Uuid
  branchId          String?       @map("branch_id") @db.Uuid
  provider          String
  providerReference String        @map("provider_reference")
  amountMinor       Int           @map("amount_minor")
  currencyCode      String        @map("currency_code")
  status            PaymentStatus
  capturedAt        DateTime?     @map("captured_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  donations         Donation[]
  receipt           Receipt?
  refunds           Refund[]

  @@index([personId])
  @@index([branchId])
  @@map("payments")
}

model Donation {
  id          String   @id @default(uuid()) @db.Uuid
  paymentId   String   @map("payment_id") @db.Uuid
  fundId      String   @map("fund_id") @db.Uuid
  personId    String?  @map("person_id") @db.Uuid
  householdId String?  @map("household_id") @db.Uuid
  donatedAt   DateTime @map("donated_at")
  createdAt   DateTime @default(now()) @map("created_at")
  fund        Fund     @relation(fields: [fundId], references: [id])
  payment     Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([fundId])
  @@index([personId])
  @@map("donations")
}

model Pledge {
  id           String   @id @default(uuid()) @db.Uuid
  personId     String   @map("person_id") @db.Uuid
  fundId       String   @map("fund_id") @db.Uuid
  amountMinor  Int      @map("amount_minor")
  currencyCode String   @map("currency_code")
  startsOn     DateTime @map("starts_on")
  endsOn       DateTime? @map("ends_on")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  fund         Fund     @relation(fields: [fundId], references: [id])

  @@index([personId])
  @@index([fundId])
  @@map("pledges")
}

model Receipt {
  id             String    @id @default(uuid()) @db.Uuid
  paymentId      String    @unique @map("payment_id") @db.Uuid
  receiptNumber  String    @unique @map("receipt_number")
  issuedAt       DateTime  @map("issued_at")
  deliveryStatus DeliveryStatus @default(PENDING) @map("delivery_status")
  createdAt      DateTime  @default(now()) @map("created_at")
  payment        Payment   @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@map("receipts")
}

model Refund {
  id           String        @id @default(uuid()) @db.Uuid
  paymentId    String        @map("payment_id") @db.Uuid
  amountMinor  Int           @map("amount_minor")
  reason       String
  status       ApprovalStatus @default(PENDING)
  approvedById String?       @map("approved_by_id") @db.Uuid
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  payment      Payment       @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@map("refunds")
}

model ReconciliationBatch {
  id              String                @id @default(uuid()) @db.Uuid
  provider        String
  batchReference  String                @unique @map("batch_reference")
  status          ReconciliationStatus  @default(OPEN)
  openedAt        DateTime              @map("opened_at")
  closedAt        DateTime?             @map("closed_at")
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  @@map("reconciliation_batches")
}

enum ReconciliationStatus {
  OPEN
  RECONCILED
  DISPUTED
  CLOSED
}

// ─────────────────────────────────────────────
// OPERATIONS & CARE
// ─────────────────────────────────────────────

model AttendanceRecord {
  id             String         @id @default(uuid()) @db.Uuid
  personId       String         @map("person_id") @db.Uuid
  branchId       String         @map("branch_id") @db.Uuid
  eventId        String?        @map("event_id") @db.Uuid
  attendedOn     DateTime       @map("attended_on")
  attendanceType AttendanceType @map("attendance_type")
  createdAt      DateTime       @default(now()) @map("created_at")
  branch         Branch         @relation(fields: [branchId], references: [id])

  @@index([personId])
  @@index([branchId])
  @@map("attendance_records")
}

model PrayerRequest {
  id          String           @id @default(uuid()) @db.Uuid
  personId    String?          @map("person_id") @db.Uuid
  branchId    String?          @map("branch_id") @db.Uuid
  requestText String           @map("request_text")
  visibility  PrayerVisibility @default(PRIVATE)
  status      FollowUpStatus   @default(NEW)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@index([personId])
  @@index([branchId])
  @@map("prayer_requests")
}

model PastoralNote {
  id           String        @id @default(uuid()) @db.Uuid
  personId     String        @map("person_id") @db.Uuid
  authorUserId String        @map("author_user_id") @db.Uuid
  noteText     String        @map("note_text")
  visibility   NoteVisibility @default(PRIVATE)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@index([personId])
  @@index([authorUserId])
  @@map("pastoral_notes")
}

model Task {
  id          String     @id @default(uuid()) @db.Uuid
  branchId    String?    @map("branch_id") @db.Uuid
  title       String
  description String?
  assignedTo  String?    @map("assigned_to") @db.Uuid
  status      TaskStatus @default(OPEN)
  dueAt       DateTime?  @map("due_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  branch      Branch?    @relation(fields: [branchId], references: [id])

  @@index([branchId])
  @@index([assignedTo])
  @@map("tasks")
}

model Document {
  id         String             @id @default(uuid()) @db.Uuid
  branchId   String?            @map("branch_id") @db.Uuid
  title      String
  storageKey String             @map("storage_key")
  visibility DocumentVisibility @default(PRIVATE)
  expiresAt  DateTime?          @map("expires_at")
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")
  branch     Branch?            @relation(fields: [branchId], references: [id])

  @@index([branchId])
  @@map("documents")
}

enum AttendanceType {
  SUNDAY_SERVICE
  MIDWEEK
  EVENT
  OTHER
}

enum PrayerVisibility {
  PRIVATE
  PASTORAL_TEAM
  BRANCH
  PUBLIC
}

enum NoteVisibility {
  PRIVATE
  PASTORAL_TEAM
  ADMIN
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum DocumentVisibility {
  PRIVATE
  BRANCH
  MEMBER
  PUBLIC
}
